DEV_CLIENT_HOSTNAME=http://localhost
DEV_CLIENT_PORT=3000
DEV_SERVER_PORT=3001
NODE_ENV=development

# Google Calendar — OAuth 2.0 authorization code (Web application client in Google Cloud Console)
# Server-only: do not put these in client/.env (Vite would expose them in the browser bundle).
VITE_GOOGLE_OAUTH_CLIENT_ID=
VITE_GOOGLE_OAUTH_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI in the Google client (e.g. http://localhost:3000/oauth/google-calendar/callback)
VITE_GOOGLE_OAUTH_REDIRECT_URI=
# Recommended: random secret for signing OAuth `state` (falls back to client secret if unset)
VITE_GOOGLE_OAUTH_STATE_SECRET=

DEV_DB_HOSTNAME=DEV_DB_HOSTNAME
DEV_DB_USERNAME=postgres
DEV_DB_PORT=5432
DEV_DB_NAME=postgres
DEV_DB_PASSWORD=DEV_DB_PASSWORD

DEV_EMAIL_USERNAME=DEV_EMAIL_USERNAME
DEV_EMAIL_PASSWORD=DEV_EMAIL_PASSWORD
DEV_EMAIL_FIRSTNAME=FIRST_NAME
DEV_EMAIL_LASTNAME=LAST_NAME